{
  "name": "chaunyoms",
  "version": "1.0.2-beta",
  "description": "Authoritative OMS memory and contextEngine substrate plugin for OpenClaw.",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "license": "MIT",
  "dependencies": {
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "scripts": {
    "postinstall": "node --experimental-sqlite scripts/check-environment.cjs --install",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test:compiled": "node scripts/run-compiled-tests.cjs",
    "test": "npm run build && npm run test:compiled",
    "doctor": "node --experimental-sqlite scripts/check-environment.cjs",
    "openclaw:case-pack": "node scripts/build-openclaw-standard-case-pack.cjs",
    "openclaw:runtime-report": "node --experimental-sqlite scripts/openclaw-runtime-report.cjs",
    "openclaw:send": "node scripts/run-openclaw-real-smoke.cjs",
    "failure-corpus": "npm run build && node dist/src/tests/test-failure-corpus.js",
    "check": "npm test && npm audit --omit=dev"
  }
}
