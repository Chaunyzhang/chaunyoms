{
  "name": "chaunyoms",
  "version": "0.1.0",
  "description": "Lightweight oms context engine plugin for OpenClaw.",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:openclaw-config": "node dist/scripts/check-openclaw-config.js",
    "fix:openclaw-config": "node dist/scripts/check-openclaw-config.js --fix",
    "restore:openclaw-config": "node dist/scripts/check-openclaw-config.js --restore",
    "test:raw-store": "node dist/scripts/test-raw-store.js",
    "test:summary-store": "node dist/scripts/test-summary-store.js",
    "test:assembler": "node dist/scripts/test-assembler.js",
    "test:recall": "node dist/scripts/test-recall.js",
    "test:memory-router": "node dist/scripts/test-memory-router.js",
    "test:external-bootstrap": "node dist/scripts/test-external-bootstrap.js",
    "test:stable-prefix": "node dist/scripts/test-stable-prefix.js",
    "test:compaction-integrity": "node dist/scripts/test-compaction-integrity.js",
    "test:memory-retrieve-auto-recall": "node dist/scripts/test-memory-retrieve-auto-recall.js",
    "test:embedding-bootstrap": "node dist/scripts/test-embedding-bootstrap.js",
    "test:runtime-fallback-lifecycle": "node dist/scripts/test-runtime-fallback-lifecycle.js"
  },
  "license": "MIT",
  "dependencies": {
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
