{
  "name": "chaunyoms",
  "version": "1.0.0-beta.1",
  "description": "Authoritative OMS memory and contextEngine substrate plugin for OpenClaw.",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "license": "MIT",
  "dependencies": {
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "scripts": {
    "postinstall": "node --experimental-sqlite scripts/check-environment.cjs --install",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test:compiled": "node scripts/run-compiled-tests.cjs",
    "test": "npm run build && npm run test:compiled",
    "doctor": "node --experimental-sqlite scripts/check-environment.cjs",
    "eval:memory": "npm run build && node dist/src/evals/run-eval-suite.js",
    "benchmark": "npm run build && node dist/src/benchmarks/benchmark-runtime.js",
    "qa:runtime-report": "node --experimental-sqlite scripts/openclaw-runtime-report.cjs",
    "qa:session-smoke": "node --experimental-sqlite scripts/openclaw-session-smoke.cjs",
    "qa:baseline": "npm run eval:memory && npm run benchmark",
    "failure-corpus": "npm run build && node dist/src/tests/test-failure-corpus.js",
    "check": "npm test && npm run eval:memory && npm run benchmark && npm audit --omit=dev",
    "eval:locomo:build": "npm run build && node dist/src/evals/build-locomo-medium-suite.js",
    "eval:locomo": "npm run eval:locomo:build && node dist/src/evals/run-eval-suite.js --suite artifacts/evals/locomo-medium-suite.json --report-prefix locomo-medium-eval-report",
    "eval:locomo:standard": "npm run build && node scripts/run-locomo-standard.cjs",
    "eval:longmemeval:standard": "npm run build && node scripts/run-longmemeval-siliconflow.cjs --data artifacts/datasets/longmemeval/longmemeval_s_cleaned.json --cases 500 --max-sessions 60",
    "eval:personamem:standard": "npm run build && node scripts/run-personamem-standard.cjs",
    "eval:prefeval10:standard": "npm run build && node scripts/run-prefeval10-standard.cjs",
    "eval:standard:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-standard-benchmarks.ps1",
    "eval:baseline:mini": "npm run build && node scripts/run-default-baseline-mini.cjs"
  }
}
